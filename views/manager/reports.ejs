<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || "Reports & Analytics" %></title>
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

  <%- include("../partials/navbar_manager.ejs") %>

  <div class="page-container">
    <h1>Reports & Analytics</h1>

    <form method="GET" action="/manager/reports" class="filter-form">
      <label for="period">Show data for last:</label>
      <select id="period" name="period" class="form-input" onchange="this.form.submit()">
        <option value="7" <%= period === '7' ? 'selected' : '' %>>7 days</option>
        <option value="30" <%= period === '30' ? 'selected' : '' %>>30 days</option>
        <option value="90" <%= period === '90' ? 'selected' : '' %>>90 days</option>
      </select>
    </form>

    <section class="section-block">
      <h2>Appointments by Status</h2>
      <% if (!appointmentsByStatus || appointmentsByStatus.length === 0) { %>
        <p>No data available.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Status</th>
              <th>Count</th>
            </tr>
          </thead>
          <tbody>
            <% appointmentsByStatus.forEach(row => { %>
              <tr>
                <td><%= row._id %></td>
                <td><%= row.count %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

    <section class="section-block">
      <h2>Appointments by Therapy</h2>
      <% if (!appointmentsByTherapy || appointmentsByTherapy.length === 0) { %>
        <p>No data available.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Therapy</th>
              <th>Count</th>
            </tr>
          </thead>
          <tbody>
            <% appointmentsByTherapy.forEach(row => { %>
              <tr>
                <td>
                  <% if (row.therapyInfo && row.therapyInfo.length > 0) { %>
                    <%= row.therapyInfo[0].name %>
                  <% } else { %>
                    Unknown
                  <% } %>
                </td>
                <td><%= row.count %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

    <section class="section-block">
      <h2>Users by Role</h2>
      <% if (!usersByRole || usersByRole.length === 0) { %>
        <p>No data available.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Role</th>
              <th>Count</th>
            </tr>
          </thead>
          <tbody>
            <% usersByRole.forEach(row => { %>
              <tr>
                <td><%= row._id %></td>
                <td><%= row.count %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>
  </div>
<%- include("../partials/footer.ejs") %>

</body>
</html>
