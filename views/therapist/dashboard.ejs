<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || "Therapist Dashboard" %></title>
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

  <%- include("../partials/navbar_therapist.ejs") %>

  <div class="page-container">
    <h1>Therapist Dashboard</h1>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-number"><%= todaySessions.length %></div>
        <div class="stat-label">Today's Sessions</div>
      </div>

      <div class="stat-card">
        <div class="stat-number"><%= completedCount %></div>
        <div class="stat-label">Completed Sessions</div>
      </div>

      <div class="stat-card">
        <div class="stat-number"><%= upcomingSessions.length %></div>
        <div class="stat-label">Upcoming Sessions</div>
      </div>
    </div>

    <section class="section-block">
      <h2>Today's Sessions</h2>

      <% if (!todaySessions || todaySessions.length === 0) { %>
        <p>No sessions scheduled for today.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Client</th>
              <th>Therapy</th>
              <th>Date</th>
              <th>Time</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% todaySessions.forEach(s => { %>
              <tr>
                <td><%= s.client.firstName %> <%= s.client.lastName %></td>
                <td><%= s.therapy ? s.therapy.name : "Not Assigned yet" %></td>
                <td><%= new Date(s.appointmentDate).toLocaleDateString() %></td>
                <td><%= s.startTime %></td>
                <td>
                  <span class="badge badge-<%= s.status === 'COMPLETED' ? 'success' : 'info' %>">
                    <%= s.status %>
                  </span>
                </td>
                <td>
                  <a href="/therapist/session/<%= s._id %>" class="btn btn-small">View</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

    <section class="section-block">
      <h2>Next Upcoming Sessions</h2>

      <% if (!upcomingSessions || upcomingSessions.length === 0) { %>
        <p>No upcoming sessions.</p>
      <% } else { %>
        <table class="table">
          <thead>
            <tr>
              <th>Client</th>
              <th>Therapy</th>
              <th>Date</th>
              <th>Time</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% upcomingSessions.forEach(s => { %>
              <tr>
                <td><%= s.client.firstName %> <%= s.client.lastName %></td>
                <td><%= s.therapy ? s.therapy.name : "Not Assigned yet" %></td>
                <td><%= new Date(s.appointmentDate).toLocaleDateString() %></td>
                <td><%= s.startTime %></td>
                <td><span class="badge badge-info"><%= s.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>
  </div>
<%- include("../partials/footer.ejs") %>

</body>
</html>
